# Même projet Supabase que l'app mobile
NEXT_PUBLIC_SUPABASE_URL=https://votre-projet.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=votre-anon-key

# Service role — UNIQUEMENT côté serveur (actions, API routes)
SUPABASE_SERVICE_ROLE_KEY=votre-service-role-key

# Emails autorisés à accéder au back-office (séparés par des virgules)
ADMIN_EMAILS=vous@amplitude.app,admin@amplitude.app

# Chiffrement des clés API stockées en base (32+ caractères)
SETTINGS_ENCRYPTION_KEY=change-me-to-a-long-random-secret

# Email de notification admin lors d'un nouvel abonnement Stripe
SUBSCRIPTION_NOTIFY_EMAIL=contact@amplitudeapp.fr

# OVH SMTP — requis pour livrer vers contact@amplitudeapp.fr (Resend/OVH bloque l'inbound)
OVH_SMTP_USER=contact@amplitudeapp.fr
OVH_SMTP_PASSWORD=mot-de-passe-boite-ovh
# OVH_SMTP_HOST=ssl0.ovh.net
# OVH_SMTP_PORT=465

# Secret partagé webhook Supabase → API interne Vercel
INTERNAL_NOTIFY_SECRET=long-random-secret
# Sur Supabase Edge Functions aussi :
# SUBSCRIPTION_NOTIFY_URL=https://amplitude-saas-kappa.vercel.app/api/internal/subscription-notify

# Webhook Stripe (endpoint: /api/stripe/webhook ou Edge Function Supabase)
STRIPE_WEBHOOK_SECRET=whsec_...

# Optionnel : clé Resend peut aussi être saisie chiffrée dans Paramètres → Envoi d'emails
# RESEND_API_KEY=re_...

# URL publique du back-office (logo des emails de campagne si non uploadé en Paramètres)
# NEXT_PUBLIC_APP_URL=https://amplitude-saas-kappa.vercel.app
